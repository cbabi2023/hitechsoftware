# Supabase Configuration
# Get these values from your Supabase project dashboard:
# 1. Go to Settings → API
# 2. Copy the Project URL and Keys
# 3. Add them to .env.local (this file is for reference only)

# Skip SWC lockfile patching (required for npm workspaces monorepo)
NEXT_IGNORE_INCORRECT_LOCKFILE=1

# Project URL from Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Publishable Key (safe to expose in frontend code)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_publishable_key

# Anon Key (safe to expose in frontend code, used for RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service Role Key (PRIVATE - NEVER expose in frontend code)
# Only use this on the server or in server actions
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional: disable client-side auth audit insert calls (useful if auth_logs migration is not applied yet)
NEXT_PUBLIC_DISABLE_AUTH_LOGS=false

# Optional: Database connection string for direct Postgres access
# DATABASE_URL=postgresql://postgres.user:password@db.supabase.co:5432/postgres
